#!/usr/bin/env bash
#SPDX-License-Identifier: MIT-0
#
# push - Push all git repos in /srv/code/tekne (wrapper around code)
#
# Usage:
#   push              # Push with default commit message "Update"
#   push -m "msg"     # Push with custom commit message
#

set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
readonly REPOS_DIR="/srv/code/tekne"

exec "$SCRIPT_DIR/code" -d "$REPOS_DIR" push "$@"
